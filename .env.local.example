ANTHROPIC_API_KEY=your_api_key_here

# Bluesky owner (uses server-side API key instead of BYOK)
OWNER_HANDLE=seldo.com
NEXT_PUBLIC_OWNER_HANDLE=seldo.com

# Twitter OAuth
TWITTER_CONSUMER_KEY=your_twitter_client_id
TWITTER_SECRET_KEY=your_twitter_client_secret
TWITTER_OWNER_HANDLE=your_twitter_handle

# Mastodon owner (format: user@instance)
MASTODON_OWNER_HANDLE=seldo@alpaca.gold
NEXT_PUBLIC_MASTODON_OWNER_HANDLE=seldo@alpaca.gold

# GitHub Copilot (optional alternative LLM provider)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
